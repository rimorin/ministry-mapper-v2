# System Configuration
VITE_SYSTEM_ENVIRONMENT=local

# OpenRouteService API Key (for routing)
VITE_OPENROUTE_API_KEY=your_openrouteservice_api_key
# LocationIQ API Key (for geocoding)
VITE_LOCATIONIQ_API_KEY=your_locationiq_api_key

# URLs
VITE_PRIVACY_URL=https://example.com/privacy
VITE_TERMS_URL=https://example.com/terms
VITE_ABOUT_URL=https://example.com/about
VITE_POCKETBASE_URL=http://localhost:8090

# Umami Analytics
VITE_UMAMI_SRC_URL=https://cloud.umami.is/script.js
VITE_UMAMI_WEBSITE_ID=your_umami_website_id
VITE_UMAMI_DOMAINS=yourdomain.com

# Sentry DSN (for error tracking)
VITE_SENTRY_DSN=https://example@sentry.io/123456

# Sentry Build-time Configuration
# SENTRY_AUTH_TOKEN=your_auth_token
# SENTRY_ORG=your_org_slug
# SENTRY_PROJECT=your_project_slug
